#!/usr/bin/env bash
# clogin - interactive cluster login selector

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CONF_FILE="${CLOGIN_CONF:-$SCRIPT_DIR/clusters.conf}"

if [[ ! -f "$CONF_FILE" ]]; then
    echo "Config not found: $CONF_FILE"
    echo "Copy clusters.conf.example to clusters.conf and add your clusters."
    exit 1
fi

# Parse config
names=()
cmds=()
while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    name="${line%%|*}"
    cmd="${line#*|}"
    names+=("$name")
    cmds+=("$cmd")
done < "$CONF_FILE"

if [[ ${#names[@]} -eq 0 ]]; then
    echo "No clusters configured in $CONF_FILE"
    exit 1
fi

# Wrap an ssh command so the remote shell runs inside a persistent tmux
# session, letting connections survive network drops — reconnecting reattaches.
#
# By default each new clogin connection gets its OWN remote session: it attaches
# to the first session that has no client attached, otherwise it creates a fresh
# uniquely-named one (e.g. vega, vega-2, vega-3). So opening a second terminal
# gives you a second, independent session, while reconnecting after a drop
# reattaches to the session you left (it now has no client) instead of spawning
# yet another one.
#
# Env overrides:
#   CLOGIN_TMUX=0               disable tmux wrapping for this run
#   CLOGIN_TMUX_SESSION=<name>  force one fixed shared session — every
#                               connection attaches to the same terminal (the
#                               old mirroring behavior)
#
# The result is placed in the global LOGIN_CMD array so the remote command can
# carry spaces/quotes without being mangled by word-splitting at the call site.
build_login_cmd() {
    local name="$1" raw="$2"
    LOGIN_CMD=()
    # Skip wrapping if disabled, or if this isn't a plain ssh command.
    if [[ "${CLOGIN_TMUX:-1}" == "0" ]] || [[ "$raw" != ssh && "$raw" != ssh\ * ]]; then
        # shellcheck disable=SC2206  # intentional word-split of the raw command
        LOGIN_CMD=($raw)
        return
    fi
    # Split the ssh options/host (everything after "ssh") into words.
    local rest="${raw#ssh}"
    # shellcheck disable=SC2206
    local ssh_args=($rest)

    local remote
    if [[ -n "${CLOGIN_TMUX_SESSION:-}" ]]; then
        # Explicit fixed session: attach-or-create it; all connections mirror it.
        remote="exec tmux new-session -A -s '$CLOGIN_TMUX_SESSION'"
    else
        # Default: one session per connection. Attach to the first session with
        # no attached client; otherwise create a fresh, uniquely-named session.
        local base="$name"
        remote="t=\$(tmux list-sessions -F '#{session_attached} #{session_name}' 2>/dev/null | awk '\$1==0{print \$2; exit}'); if [ -n \"\$t\" ]; then exec tmux attach-session -t \"\$t\"; fi; if tmux has-session -t '$base' 2>/dev/null; then i=2; while tmux has-session -t \"$base-\$i\" 2>/dev/null; do i=\$((i+1)); done; exec tmux new-session -s \"$base-\$i\"; else exec tmux new-session -s '$base'; fi"
    fi
    # -t forces a TTY (required for tmux over a remote command).
    LOGIN_CMD=(ssh -t "${ssh_args[@]}" "$remote")
}

count=${#names[@]}
selected=0

# Draw the menu
draw_menu() {
    # Move cursor up to overwrite previous menu (except on first draw)
    if [[ "${1:-}" == "redraw" ]]; then
        printf '\033[%dA' "$count"
    fi
    for i in "${!names[@]}"; do
        if [[ $i -eq $selected ]]; then
            printf '\033[1;32m > %s\033[0m\n' "${names[$i]}"
        else
            printf '   %s\n' "${names[$i]}"
        fi
    done
}

# Read a single keypress (handles arrow key escape sequences)
read_key() {
    local key
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
        IFS= read -rsn2 key
        case "$key" in
            '[A') echo "up" ;;
            '[B') echo "down" ;;
            *)    echo "" ;;
        esac
    elif [[ "$key" == "" ]]; then
        echo "enter"
    elif [[ "$key" == "k" ]]; then
        echo "up"
    elif [[ "$key" == "j" ]]; then
        echo "down"
    elif [[ "$key" == "q" ]]; then
        echo "quit"
    else
        echo ""
    fi
}

# Hide cursor, restore on exit
trap 'printf "\033[?25h"' EXIT
printf '\033[?25h'

echo "Select a cluster (↑/↓ or j/k, Enter to connect, q to quit):"
echo ""
draw_menu first

while true; do
    key=$(read_key)
    case "$key" in
        up)
            if ((selected > 0)); then ((selected--)); fi
            draw_menu redraw
            ;;
        down)
            if ((selected < count - 1)); then ((selected++)); fi
            draw_menu redraw
            ;;
        enter)
            echo ""
            echo "Connecting to ${names[$selected]}..."
            build_login_cmd "${names[$selected]}" "${cmds[$selected]}"
            exec "${LOGIN_CMD[@]}"
            ;;
        quit)
            echo ""
            echo "Cancelled."
            exit 0
            ;;
    esac
done
